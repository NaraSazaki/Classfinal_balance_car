# Keil uVision user/session files.
*.uvguix.*
*.uvgui.*
*.uvgui
*.uvopt

# Keil/MDK build output.
**/MDK-ARM/**/Listings/
**/MDK-ARM/**/Objects/
**/MDK-ARM/*/*.o
**/MDK-ARM/*/*.d
**/MDK-ARM/*/*.axf
**/MDK-ARM/*/*.elf
**/MDK-ARM/*/*.map
**/MDK-ARM/*/*.lnp
**/MDK-ARM/*/*.dep
**/MDK-ARM/*/*.htm
**/MDK-ARM/*/*.html
**/MDK-ARM/*/*.build_log.htm
**/MDK-ARM/*/*.crf
**/MDK-ARM/*/*.lst
**/MDK-ARM/*/*.bak

# Firmware artifacts generated by builds.
**/MDK-ARM/*/*.hex
**/MDK-ARM/*/*.bin

# Keep scatter/linker files that are needed by the project.
!**/MDK-ARM/*/*.sct
!**/*.ld
